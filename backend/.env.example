# JWT Secret Key (сгенерировать через python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here

# Алгоритм JWT
ALGORITHM=HS256

# Время жизни access-токена (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Пароль для PostgreSQL (должен совпадать с docker-compose.yml)
POSTGRES_PASSWORD=postgres123

# Окружение: development или production
ENVIRONMENT=development